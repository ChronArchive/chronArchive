[Unit]
Description=Chronograph Admin Panel (Tailscale only)
After=network.target chronograph-chat.service
Wants=chronograph-chat.service

[Service]
WorkingDirectory=/opt/chronograph-chat
ExecStart=/opt/chronograph-chat/venv/bin/python3 /opt/chronograph-chat/admin_panel.py
Restart=on-failure
RestartSec=5
Environment=CG_DB=/opt/chronograph-chat/chat.db

[Install]
WantedBy=default.target
